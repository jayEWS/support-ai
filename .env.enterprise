# Environment variables for Enterprise AI Platform

# ── Database (SQL Server) ──
DATABASE_URL=mssql+pyodbc://sa:SuperS3cureP@ssword123@db:1433/support_ai?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
SA_PASSWORD=SuperS3cureP@ssword123

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=True

# ── Qdrant Vector Database ──
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── Prometheus Monitoring ──
PROMETHEUS_ENABLED=True

# ── AI Configuration ──
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
EMBEDDINGS_TYPE=local
EMBEDDINGS_MODEL_NAME=all-MiniLM-L6-v2

# ── Security ──
API_SECRET_KEY=your-super-secure-api-secret-key-change-this-in-production
AUTH_SECRET_KEY=your-super-secure-auth-secret-key-change-this-in-production
ALLOWED_ORIGINS=["http://localhost", "http://localhost:80"]

# ── Multi-tenant & Features ──
MULTI_TENANT_ENABLED=False
DEFAULT_TENANT_ID=enterprise
PLAN_ENFORCEMENT_ENABLED=False
AI_OBSERVABILITY_ENABLED=True
AI_COST_TRACKING_ENABLED=True

# ── Application ──
DEBUG=False
BASE_URL=http://localhost

# ── Email (Optional) ──
EMAIL_PROVIDER=gmail
GMAIL_EMAIL=your-gmail@gmail.com
GMAIL_PASSWORD=your-app-password
EMAIL_FROM_ADDRESS=your-gmail@gmail.com