# ============================================================
# Support Portal Edgeworks - Environment Configuration (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in all required values
# NEVER commit actual credentials to the repository
# Use your host's secret store (Render, Vercel, Azure, GitHub Actions secrets, etc.)
# ============================================================

# ============ AI & LLM Configuration ============
OPENAI_API_KEY=sk-your-openai-api-key-here
MODEL_NAME=gpt-4o-mini
AI_BASE_URL=
TEMPERATURE=0.3

# ============ Embeddings Configuration ============
EMBEDDINGS_TYPE=local
EMBEDDINGS_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDINGS_BASE_URL=

# ============ Database Configuration ============
# Replace with your DB connection string (do NOT commit credentials)
# Example (Postgres / Supabase):
# postgresql+psycopg2://username:password@host:5432/database
DATABASE_URL=postgresql+psycopg2://postgres:your_password@your_host:5432/postgres

# ============ Security Configuration ============
API_SECRET_KEY=your-very-secure-random-secret-key-minimum-32-chars
AUTH_SECRET_KEY=your-very-secure-auth-secret-key-minimum-32-chars

# Cookie Security (PRODUCTION SETTINGS)
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============ OAuth Configuration ============
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# ============ WhatsApp Cloud API (Meta) ============
WHATSAPP_API_TOKEN=           # Permanent token from Meta Business dashboard
WHATSAPP_PHONE_NUMBER_ID=     # Phone Number ID from WhatsApp > API Setup
WHATSAPP_BUSINESS_ACCOUNT_ID= # WABA ID from Meta Business dashboard
WHATSAPP_VERIFY_TOKEN=edgeworks_wa_verify_2024  # Your custom webhook verify token
WHATSAPP_APP_SECRET=          # Meta App Secret (for webhook signature validation)

# ============ Email / SMTP (Gmail) ============
# If using Gmail, enable 2-Step verification and generate an App Password
# DO NOT store real credentials in the repository — use secret stores
EMAIL_PROVIDER=gmail
GMAIL_EMAIL=your_email@yourdomain.com
GMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM_ADDRESS=your_email@yourdomain.com

# ============ Mailgun ============
MAILGUN_API_KEY=
MAILGUN_DOMAIN=yourdomain.com

# ============ Application Settings ============
BASE_URL=https://yourdomain.com
KNOWLEDGE_DIR=data/knowledge
DB_DIR=data/db_storage

# ============ Deployment Settings ============
DEBUG=false
