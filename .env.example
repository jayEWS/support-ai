# ============================================================
# Edgeworks Support AI — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ============================================================

# ── Database ──
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# POS_DB_URL=mssql+pyodbc://user:pass@host/db?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# ── Security (REQUIRED for production) ──
AUTH_SECRET_KEY=          # Min 32 chars. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
API_SECRET_KEY=           # Min 32 chars. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
DEBUG=False
COOKIE_SECURE=True
COOKIE_SAMESITE=strict

# ── LLM Provider (choose one) ──
LLM_PROVIDER=groq         # groq | ollama | vertex | gemini | openai
GROQ_API_KEY=
MODEL_NAME=llama-3.3-70b-versatile

# Ollama (local, free)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_FALLBACK_MODEL=qwen2.5:7b

# Google Vertex AI
# GCP_PROJECT_ID=
# VERTEX_AI_MODEL=gemini-2.5-flash

# Google Gemini
# GOOGLE_GEMINI_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# ── Google OAuth ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# ── Email ──
EMAIL_PROVIDER=gmail       # gmail | sendgrid | mock
GMAIL_EMAIL=
GMAIL_PASSWORD=            # App password, not regular password
EMAIL_FROM_ADDRESS=

# ── WhatsApp (Meta Cloud API) ──
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=     # Your custom verify token for webhook registration
WHATSAPP_APP_SECRET=       # From Meta App Dashboard → Settings → App Secret
WHATSAPP_TEST_MODE=False   # Set True ONLY for local development

# ── MFA ──
MFA_ENABLED=True
MFA_DEV_RETURN_CODE=False  # Set True ONLY for local development (returns code in response)

# ── Redis (optional, for multi-worker state sharing) ──
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379

# ── Google Cloud Storage (optional) ──
GCS_ENABLED=False
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Prometheus Metrics (optional) ──
PROMETHEUS_ENABLED=False

# ── Multi-Tenant SaaS (optional) ──
MULTI_TENANT_ENABLED=False
DEFAULT_TENANT_ID=default
