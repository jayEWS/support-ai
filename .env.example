# ============ DATABASE ============
POSTGRES_DB=support_portal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_change_me_in_production

# Database connection string (auto-generated from above in docker-compose)
DATABASE_URL=postgresql://postgres:postgres_secure_password_change_me_in_production@localhost:5432/support_portal

# ============ REDIS ============
REDIS_PASSWORD=redis_secure_password_change_me_in_production
REDIS_URL=redis://:redis_secure_password_change_me_in_production@localhost:6379/0

# ============ FASTAPI ============
DEBUG=False
ENVIRONMENT=production
BASE_URL=http://localhost:8000
API_SECRET_KEY=your_secret_key_here_change_in_production

# ============ SECURITY ============
AUTH_SECRET_KEY=your_jwt_secret_key_here_change_in_production_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (set specific origins for production, NOT wildcard)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# ============ AI SERVICES ============
# Gemini / Vertex AI
GEMINI_API_KEY=your_gemini_api_key_here
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1

# Groq LLM (free alternative to Gemini)
GROQ_API_KEY=your_groq_api_key_here

# ============ AUTHENTICATION ============
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ============ WHATSAPP ============
# Meta Cloud API credentials
WHATSAPP_API_TOKEN=your_meta_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_TEST_MODE=False

# ============ EMAIL ============
# Gmail SMTP for notifications
GMAIL_EMAIL=your_gmail_email@gmail.com
GMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_PROVIDER=gmail

# ============ GOOGLE CLOUD STORAGE (Optional) ============
GCS_BUCKET_NAME=your_gcs_bucket_name
GOOGLE_APPLICATION_CREDENTIALS=/app/gcs-key.json

# ============ KNOWLEDGE BASE ============
KNOWLEDGE_DIR=./data/knowledge
RAG_SERVICE_TYPE=faiss  # or qdrant for enterprise

# ============ MONITORING ============
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# ============ MULTI-TENANT (SaaS) ============
MULTI_TENANT_ENABLED=False
PLAN_ENFORCEMENT_ENABLED=False
AI_OBSERVABILITY_ENABLED=True

# ============ FEATURE FLAGS ============
COOKIE_SECURE=False  # Set to True in production with HTTPS
COOKIE_SAMESITE=Lax
