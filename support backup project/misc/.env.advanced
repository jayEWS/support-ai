# ============ ENHANCED RAG CONFIGURATION (.env additions) ============
# Copy these to your .env file for advanced features

# ============ HYBRID SEARCH SETUP ============
# Enable hybrid search (BM25 + Vector) - significantly improves recall
RAG_HYBRID_SEARCH_ENABLED=true
RAG_BM25_WEIGHT=0.4
RAG_VECTOR_WEIGHT=0.6

# Vector Store Options: "faiss" or "chromadb"
# ChromaDB: Persistent by default, survives restart, easier than FAISS
VECTOR_STORE_TYPE=faiss  # Switch to "chromadb" for persistent storage

# ============ LLM PROVIDER OPTIONS ============
# Options: "openai", "groq", "ollama"
# Groq is FREE, FAST (< 1s for WhatsApp)
LLM_PROVIDER=openai  # Switch to "groq" for free tier + speed
GROQ_API_KEY=your_groq_api_key_here

# Ollama (local LLM) - completely free, runs on your server
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2  # or "qwen:7b" for multilingual

# ============ OBSERVABILITY & TRACING ============
# Langfuse (free tier): RAG tracing, debugging, cost monitoring
# Self-host: https://langfuse.com/docs/self-host
LANGFUSE_PUBLIC_KEY=your_langfuse_key
LANGFUSE_SECRET_KEY=your_langfuse_secret
LANGFUSE_HOST=https://cloud.langfuse.com  # or your self-hosted instance

# Enable/disable Langfuse logging
LANGFUSE_ENABLED=false

# ============ RAG EVALUATION ============
# Enable offline RAG quality testing
RAG_EVAL_ENABLED=true
RAG_EVAL_THRESHOLD=0.6  # Minimum score for pass (0-1)

# ============ RATE LIMITING ============
# Prevent WhatsApp webhook abuse
RATE_LIMIT_WEBHOOK=10/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_CHAT=20/minute

# ============ DEPLOYMENT ============
# For Render.com or Railway.app
PORT=8000
WORKERS=4

# Redis (optional, for distributed rate limiting)
REDIS_URL=  # Leave empty for in-memory store, or set to redis://localhost:6379

# ============ DOCUMENT PROCESSING ============
# Better PDF/DOCX handling with unstructured
UNSTRUCTURED_ENABLED=true
CHUNK_SIZE=1024
CHUNK_OVERLAP=200

# ============ ADVANCED RAG SETTINGS ============
# Confidence threshold for RAG responses
RAG_CONFIDENCE_THRESHOLD=0.5

# Number of documents to retrieve
RAG_TOP_K=5

# Allow keyword search fallback when semantic fails
RAG_FALLBACK_TO_BM25=true

# Enable conversational memory for multi-turn chat
ENABLE_CONVERSATION_MEMORY=true
MAX_CONVERSATION_HISTORY=20  # Number of messages to keep in memory
